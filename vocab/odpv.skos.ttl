<https://opendataproducts.org/odpv-v1.0/terms/belongsTo> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "belongs to"@en ;
  skos:definition "Indicates that one object is assigned to, grouped under, or included in another object, such as a data product belonging to a catalog."@en ;
  skos:notation "belongsTo" ;
  dcterms:type "relationship" ;
  dcterms:isPartOf "relationships" ;
