<https://opendataproducts.org/odpv-v1.0/terms/indicates> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "indicates"@en ;
  skos:definition "Indicates that one object points to, reveals, or suggests another object, such as a signal indicating a gap, demand, risk, or opportunity."@en ;
  skos:notation "indicates" ;
  dcterms:type "relationship" ;
  dcterms:isPartOf "relationships" ;
  skos:altLabel "points to"@en, "suggests"@en, "reveals"@en, "signals"@en ;
