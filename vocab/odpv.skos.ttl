<https://opendataproducts.org/odpv-v1.0/terms/consumes> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "consumes"@en ;
  skos:definition "Indicates that one object consumes data, services, outputs, or interfaces from another object."@en ;
  skos:notation "consumes" ;
