@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix schema: <https://schema.org/> .

<https://opendataproducts.org/odpv-v1.0/> a skos:ConceptScheme ;
  skos:prefLabel "Open Data Product Vocabulary"@en ;
  skos:definition "Shared vocabulary for the OpenDataProducts.org standards family."@en .

<https://opendataproducts.org/odpv-v1.0/terms/DataProduct> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Data Product"@en ;
  skos:definition "A managed data offering designed for reuse, with defined ownership, access, quality, usage terms, and value context."@en ;
  skos:notation "DataProduct" ;
  dcterms:type "object" ;
  dcterms:isPartOf "core" ;
  skos:altLabel "data product"@en, "data offering"@en, "reusable data asset"@en, "data product asset"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/Dataset>, <https://opendataproducts.org/odpv-v1.0/terms/DataService>, <https://opendataproducts.org/odpv-v1.0/terms/Distribution> .

<https://opendataproducts.org/odpv-v1.0/terms/ProductDetails> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Product Details"@en ;
  skos:definition "The descriptive metadata block for a data product, including name, product identifier, description, value proposition, visibility, status, and version."@en ;
  skos:notation "ProductDetails" ;
  dcterms:type "object" ;
  dcterms:isPartOf "core" ;
  skos:altLabel "details"@en, "product details"@en, "product metadata"@en, "descriptive metadata"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/DataProduct>, <https://opendataproducts.org/odpv-v1.0/terms/ValueProposition>, <https://opendataproducts.org/odpv-v1.0/terms/GovernanceProfile>, <https://opendataproducts.org/odpv-v1.0/terms/PortfolioPriority> .

<https://opendataproducts.org/odpv-v1.0/terms/DataProductCatalog> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Data Product Catalog"@en ;
  skos:definition "A managed collection of data products and related portfolio objects, such as use cases, objectives, KPIs, signals, and references."@en ;
  skos:notation "DataProductCatalog" ;
  dcterms:type "object" ;
  dcterms:isPartOf "core" ;
  skos:altLabel "data catalog"@en, "Catalog"@en, "ODPC Catalog"@en, "product catalog"@en, "data product portfolio"@en, "portfolio catalog"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/DataProduct>, <https://opendataproducts.org/odpv-v1.0/terms/DataProductGraph>, <https://opendataproducts.org/odpv-v1.0/terms/Reference> ;
  skos:closeMatch dcat:Catalog, schema:DataCatalog .

<https://opendataproducts.org/odpv-v1.0/terms/DataProductGraph> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Data Product Graph"@en ;
  skos:definition "A graph representation that connects data products, catalogs, use cases, objectives, KPIs, signals, and governance objects through defined relationships."@en ;
  skos:notation "DataProductGraph" ;
  dcterms:type "object" ;
  dcterms:isPartOf "core" ;
  skos:altLabel "data product graph"@en, "portfolio graph"@en, "knowledge graph"@en, "product relationship graph"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/DataProductCatalog>, <https://opendataproducts.org/odpv-v1.0/terms/Reference> .

<https://opendataproducts.org/odpv-v1.0/terms/Dataset> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Dataset"@en ;
  skos:definition "A structured collection of data that may be part of, or exposed through, a data product. Aligns with DCAT where applicable."@en ;
  skos:notation "Dataset" ;
  dcterms:type "object" ;
  dcterms:isPartOf "core" ;
  skos:altLabel "data set"@en, "data collection"@en, "source dataset"@en, "data resource"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/DataProduct>, <https://opendataproducts.org/odpv-v1.0/terms/Distribution>, <https://opendataproducts.org/odpv-v1.0/terms/DataService> ;
  skos:exactMatch dcat:Dataset, schema:Dataset .

<https://opendataproducts.org/odpv-v1.0/terms/Distribution> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Distribution"@en ;
  skos:definition "A specific accessible form of a dataset, such as a file, API response, export, or downloadable representation. Aligns with DCAT where applicable."@en ;
  skos:notation "Distribution" ;
  dcterms:type "object" ;
  dcterms:isPartOf "core" ;
  skos:altLabel "data file"@en, "data download"@en, "export"@en, "data representation"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/Dataset>, <https://opendataproducts.org/odpv-v1.0/terms/DataService>, <https://opendataproducts.org/odpv-v1.0/terms/DataAccess> ;
  skos:exactMatch dcat:Distribution ;
  skos:closeMatch schema:DataDownload .

<https://opendataproducts.org/odpv-v1.0/terms/DataService> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Data Service"@en ;
  skos:definition "A service that provides access to data or data operations, such as an API, query endpoint, or data delivery service. Aligns with DCAT where applicable."@en ;
  skos:notation "DataService" ;
  dcterms:type "object" ;
  dcterms:isPartOf "core" ;
  skos:altLabel "data API"@en, "API"@en, "data endpoint"@en, "query service"@en, "delivery service"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/Dataset>, <https://opendataproducts.org/odpv-v1.0/terms/Distribution>, <https://opendataproducts.org/odpv-v1.0/terms/DataAccess> ;
  skos:exactMatch dcat:DataService .

<https://opendataproducts.org/odpv-v1.0/terms/Agent> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Agent"@en ;
  skos:definition "An AI agent, automation actor, or software system that can use data products, services, workflows, or graph context to perform a task."@en ;
  skos:notation "Agent" ;
  dcterms:type "role" ;
  dcterms:isPartOf "core" ;
  skos:altLabel "AI agent"@en, "automation actor"@en, "autonomous agent"@en, "software agent"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/Consumer>, <https://opendataproducts.org/odpv-v1.0/terms/Workflow>, <https://opendataproducts.org/odpv-v1.0/terms/DataService> ;
  skos:closeMatch prov:Agent .

<https://opendataproducts.org/odpv-v1.0/terms/Workflow> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Workflow"@en ;
  skos:definition "A business, operational, analytical, or technical process that coordinates activities, systems, agents, data products, or services."@en ;
  skos:notation "Workflow" ;
  dcterms:type "object" ;
  dcterms:isPartOf "core" ;
  skos:altLabel "process"@en, "business workflow"@en, "technical workflow"@en, "orchestration flow"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/UseCase>, <https://opendataproducts.org/odpv-v1.0/terms/Agent>, <https://opendataproducts.org/odpv-v1.0/terms/Capability> ;
  skos:closeMatch prov:Activity .

<https://opendataproducts.org/odpv-v1.0/terms/Capability> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Capability"@en ;
  skos:definition "A reusable business, organizational, analytical, operational, or technical ability that can be supported by data products, workflows, agents, or services."@en ;
  skos:notation "Capability" ;
  dcterms:type "object" ;
  dcterms:isPartOf "core" ;
  skos:altLabel "business capability"@en, "technical capability"@en, "organizational capability"@en, "reusable capability"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/Domain>, <https://opendataproducts.org/odpv-v1.0/terms/Workflow>, <https://opendataproducts.org/odpv-v1.0/terms/StrategicOpportunity> .

<https://opendataproducts.org/odpv-v1.0/terms/Provider> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Provider"@en ;
  skos:definition "A person, team, organization, or system that provides or publishes a data product, dataset, distribution, or data service."@en ;
  skos:notation "Provider" ;
  dcterms:type "role" ;
  dcterms:isPartOf "core" ;
  skos:altLabel "publisher"@en, "supplier"@en, "source provider"@en, "data provider"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/Owner>, <https://opendataproducts.org/odpv-v1.0/terms/Steward>, <https://opendataproducts.org/odpv-v1.0/terms/Consumer> .

<https://opendataproducts.org/odpv-v1.0/terms/DataHolder> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Data Holder"@en ;
  skos:definition "A legal entity or accountable organization that holds, controls, or is responsible for a data product or the data it contains."@en ;
  skos:notation "DataHolder" ;
  dcterms:type "role" ;
  dcterms:isPartOf "core" ;
  skos:altLabel "dataHolder"@en, "data holder"@en, "holding organization"@en, "accountable legal entity"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/Provider>, <https://opendataproducts.org/odpv-v1.0/terms/Owner>, <https://opendataproducts.org/odpv-v1.0/terms/Steward>, <https://opendataproducts.org/odpv-v1.0/terms/DataAgreement> .

<https://opendataproducts.org/odpv-v1.0/terms/Consumer> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Consumer"@en ;
  skos:definition "A person, team, organization, system, or agent that uses or consumes a data product, dataset, distribution, or data service."@en ;
  skos:notation "Consumer" ;
  dcterms:type "role" ;
  dcterms:isPartOf "core" ;
  skos:altLabel "user"@en, "data user"@en, "customer"@en, "recipient"@en, "consuming agent"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/Provider>, <https://opendataproducts.org/odpv-v1.0/terms/DataProduct>, <https://opendataproducts.org/odpv-v1.0/terms/DataAccess> .

<https://opendataproducts.org/odpv-v1.0/terms/Owner> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Owner"@en ;
  skos:definition "A person, team, or organization accountable for a data product, catalog, dataset, service, or related object."@en ;
  skos:notation "Owner" ;
  dcterms:type "role" ;
  dcterms:isPartOf "core" ;
  skos:altLabel "accountable owner"@en, "product owner"@en, "business owner"@en, "asset owner"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/Provider>, <https://opendataproducts.org/odpv-v1.0/terms/Steward> .

<https://opendataproducts.org/odpv-v1.0/terms/Steward> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Steward"@en ;
  skos:definition "A person, team, or organization responsible for the operational management, quality, metadata, and lifecycle of a data product or related object."@en ;
  skos:notation "Steward" ;
  dcterms:type "role" ;
  dcterms:isPartOf "core" ;
  skos:altLabel "data steward"@en, "product steward"@en, "metadata steward"@en, "quality steward"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/Owner>, <https://opendataproducts.org/odpv-v1.0/terms/Provider>, <https://opendataproducts.org/odpv-v1.0/terms/DataQuality> .

<https://opendataproducts.org/odpv-v1.0/terms/Domain> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Domain"@en ;
  skos:definition "A business, organizational, subject, or functional area used to group data products and related objects."@en ;
  skos:notation "Domain" ;
  dcterms:type "classification" ;
  dcterms:isPartOf "core" ;
  skos:altLabel "business domain"@en, "data domain"@en, "subject area"@en, "functional area"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/DataProductCatalog> .

<https://opendataproducts.org/odpv-v1.0/terms/Identifier> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Identifier"@en ;
  skos:definition "A stable value used to uniquely identify a vocabulary term, specification object, product, catalog item, or graph node."@en ;
  skos:notation "Identifier" ;
  dcterms:type "reference" ;
  dcterms:isPartOf "core" ;
  skos:altLabel "id"@en, "unique id"@en, "persistent id"@en, "node id"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/Reference>, <https://opendataproducts.org/odpv-v1.0/terms/DataProduct> .

<https://opendataproducts.org/odpv-v1.0/terms/Reference> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Reference"@en ;
  skos:definition "A link or pointer to another object, specification file, external vocabulary term, system record, or graph node."@en ;
  skos:notation "Reference" ;
  dcterms:type "reference" ;
  dcterms:isPartOf "core" ;
  skos:altLabel "link"@en, "pointer"@en, "external reference"@en, "object reference"@en, "GraphReference"@en, "ProductReference"@en, "ProductModel"@en, "graph reference"@en, "product reference"@en, "product model reference"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/Identifier>, <https://opendataproducts.org/odpv-v1.0/terms/DataProduct>, <https://opendataproducts.org/odpv-v1.0/terms/DataProductGraph> .

<https://opendataproducts.org/odpv-v1.0/terms/UseCase> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Use Case"@en ;
  skos:definition "A practical business, operational, analytical, or technical scenario where one or more data products are used to create value."@en ;
  skos:notation "UseCase" ;
  dcterms:type "object" ;
  dcterms:isPartOf "value" ;
  skos:altLabel "use case"@en, "scenario"@en, "business scenario"@en, "application case"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/DataProduct>, <https://opendataproducts.org/odpv-v1.0/terms/BusinessObjective>, <https://opendataproducts.org/odpv-v1.0/terms/DataNeed>, <https://opendataproducts.org/odpv-v1.0/terms/Outcome> .

<https://opendataproducts.org/odpv-v1.0/terms/BusinessObjective> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Business Objective"@en ;
  skos:definition "A business goal or intended outcome that data products, use cases, or portfolio actions support."@en ;
  skos:notation "BusinessObjective" ;
  dcterms:type "object" ;
  dcterms:isPartOf "value" ;
  skos:altLabel "objective"@en, "business goal"@en, "strategic goal"@en, "target outcome"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/Outcome>, <https://opendataproducts.org/odpv-v1.0/terms/KPI>, <https://opendataproducts.org/odpv-v1.0/terms/Impact>, <https://opendataproducts.org/odpv-v1.0/terms/UseCase> .

<https://opendataproducts.org/odpv-v1.0/terms/KPI> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "KPI"@en ;
  skos:definition "A measurable indicator used to track progress toward a business objective, outcome, or portfolio goal."@en ;
  skos:notation "KPI" ;
  dcterms:type "object" ;
  dcterms:isPartOf "value" ;
  skos:altLabel "key performance indicator"@en, "metric"@en, "performance measure"@en, "success measure"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/BusinessObjective>, <https://opendataproducts.org/odpv-v1.0/terms/Outcome>, <https://opendataproducts.org/odpv-v1.0/terms/Impact> .

<https://opendataproducts.org/odpv-v1.0/terms/Impact> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Impact"@en ;
  skos:definition "The expected or observed effect created by a data product, use case, signal, or portfolio decision."@en ;
  skos:notation "Impact" ;
  dcterms:type "object" ;
  dcterms:isPartOf "value" ;
  skos:altLabel "effect"@en, "value impact"@en, "business impact"@en, "observed effect"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/Outcome>, <https://opendataproducts.org/odpv-v1.0/terms/Benefit>, <https://opendataproducts.org/odpv-v1.0/terms/KPI>, <https://opendataproducts.org/odpv-v1.0/terms/ValueProposition> .

<https://opendataproducts.org/odpv-v1.0/terms/Signal> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Signal"@en ;
  skos:definition "An observed demand, trend, risk, gap, usage pattern, policy change, market change, or operational event that may require action."@en ;
  skos:notation "Signal" ;
  dcterms:type "object" ;
  dcterms:isPartOf "value" ;
  skos:altLabel "market signal"@en, "demand signal"@en, "trigger"@en, "observation"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/Demand>, <https://opendataproducts.org/odpv-v1.0/terms/Risk>, <https://opendataproducts.org/odpv-v1.0/terms/Gap>, <https://opendataproducts.org/odpv-v1.0/terms/Opportunity> .

<https://opendataproducts.org/odpv-v1.0/terms/Gap> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Gap"@en ;
  skos:definition "A missing data product, dataset, capability, quality level, access method, relationship, or portfolio coverage area."@en ;
  skos:notation "Gap" ;
  dcterms:type "object" ;
  dcterms:isPartOf "value" ;
  skos:altLabel "missing capability"@en, "coverage gap"@en, "data gap"@en, "portfolio gap"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/DataNeed>, <https://opendataproducts.org/odpv-v1.0/terms/Opportunity>, <https://opendataproducts.org/odpv-v1.0/terms/Signal>, <https://opendataproducts.org/odpv-v1.0/terms/Priority> .

<https://opendataproducts.org/odpv-v1.0/terms/Priority> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Priority"@en ;
  skos:definition "A ranking or importance level used to guide portfolio planning, product development, investment, or remediation."@en ;
  skos:notation "Priority" ;
  dcterms:type "classification" ;
  dcterms:isPartOf "value" ;
  skos:altLabel "importance level"@en, "ranking"@en, "urgency"@en, "priority level"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/PortfolioPriority>, <https://opendataproducts.org/odpv-v1.0/terms/Signal>, <https://opendataproducts.org/odpv-v1.0/terms/Gap>, <https://opendataproducts.org/odpv-v1.0/terms/Risk> .

<https://opendataproducts.org/odpv-v1.0/terms/Outcome> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Outcome"@en ;
  skos:definition "A desired or achieved result connected to a business objective, use case, KPI, or impact statement."@en ;
  skos:notation "Outcome" ;
  dcterms:type "object" ;
  dcterms:isPartOf "value" ;
  skos:altLabel "result"@en, "target result"@en, "achieved result"@en, "intended outcome"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/BusinessObjective>, <https://opendataproducts.org/odpv-v1.0/terms/KPI>, <https://opendataproducts.org/odpv-v1.0/terms/Impact>, <https://opendataproducts.org/odpv-v1.0/terms/Benefit> .

<https://opendataproducts.org/odpv-v1.0/terms/DataNeed> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Data Need"@en ;
  skos:definition "A required data input, data product, dataset, attribute, capability, or access pattern needed to support a use case or objective."@en ;
  skos:notation "DataNeed" ;
  dcterms:type "object" ;
  dcterms:isPartOf "value" ;
  skos:altLabel "data requirement"@en, "data demand"@en, "required data"@en, "information need"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/UseCase>, <https://opendataproducts.org/odpv-v1.0/terms/Gap>, <https://opendataproducts.org/odpv-v1.0/terms/Demand>, <https://opendataproducts.org/odpv-v1.0/terms/DataProduct> .

<https://opendataproducts.org/odpv-v1.0/terms/Benefit> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "Benefit"@en ;
  skos:definition "A positive business, operational, financial, social, or technical value expected from a data product, use case, or portfolio action."@en ;
  skos:notation "Benefit" ;
  dcterms:type "object" ;
  dcterms:isPartOf "value" ;
