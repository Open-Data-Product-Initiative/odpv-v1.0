<https://opendataproducts.org/odpv-v1.0/terms/dependsOn> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "depends on"@en ;
  skos:definition "Indicates that one object has a dependency on another object, such as a data product depending on another product, service, or dataset."@en ;
  skos:notation "dependsOn" ;
  dcterms:type "relationship" ;
  dcterms:isPartOf "relationships" ;
  skos:altLabel "relies on"@en, "has dependency on"@en, "uses dependency"@en, "is dependent on"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/requires>, <https://opendataproducts.org/odpv-v1.0/terms/relatedTo>, <https://opendataproducts.org/odpv-v1.0/terms/derivedFrom> .

<https://opendataproducts.org/odpv-v1.0/terms/governedBy> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "governed by"@en ;
  skos:definition "Indicates that one object is governed by another object, such as a data product governed by a license, policy, agreement, or compliance rule."@en ;
  skos:notation "governedBy" ;
  dcterms:type "relationship" ;
  dcterms:isPartOf "relationships" ;
  skos:altLabel "controlled by"@en, "regulated by"@en, "subject to"@en, "under governance of"@en ;
