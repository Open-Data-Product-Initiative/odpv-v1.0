  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "supports"@en ;
  skos:definition "Indicates that one object helps enable, serve, or make another object possible, such as a data product supporting a use case."@en ;
  skos:notation "supports" ;
  dcterms:type "relationship" ;
  dcterms:isPartOf "relationships" ;
  skos:altLabel "enables"@en, "serves"@en, "helps"@en, "provides support for"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/contributesTo>, <https://opendataproducts.org/odpv-v1.0/terms/requires>, <https://opendataproducts.org/odpv-v1.0/terms/relatedTo> .

<https://opendataproducts.org/odpv-v1.0/terms/requires> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "requires"@en ;
  skos:definition "Indicates that one object needs another object to be complete, useful, or executable, such as a use case requiring a data product."@en ;
  skos:notation "requires" ;
  dcterms:type "relationship" ;
  dcterms:isPartOf "relationships" ;
  skos:altLabel "needs"@en, "depends on"@en, "must have"@en, "requires input from"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/dependsOn>, <https://opendataproducts.org/odpv-v1.0/terms/supports>, <https://opendataproducts.org/odpv-v1.0/terms/DataNeed> .

<https://opendataproducts.org/odpv-v1.0/terms/uses> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "uses"@en ;
  skos:definition "Indicates that one object uses another object as part of execution, operation, analysis, automation, or decision-making."@en ;
  skos:notation "uses" ;
  dcterms:type "relationship" ;
  dcterms:isPartOf "relationships" ;
  skos:altLabel "uses"@en, "uses as input"@en, "makes use of"@en, "operates with"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/requires>, <https://opendataproducts.org/odpv-v1.0/terms/dependsOn>, <https://opendataproducts.org/odpv-v1.0/terms/consumes> ;
  skos:closeMatch prov:used .

<https://opendataproducts.org/odpv-v1.0/terms/contributesTo> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "contributes to"@en ;
  skos:definition "Indicates that one object helps advance another object, such as a use case contributing to a business objective."@en ;
  skos:notation "contributesTo" ;
  dcterms:type "relationship" ;
  dcterms:isPartOf "relationships" ;
  skos:altLabel "advances"@en, "helps achieve"@en, "adds value to"@en, "supports progress toward"@en ;
  skos:related <https://opendataproducts.org/odpv-v1.0/terms/supports>, <https://opendataproducts.org/odpv-v1.0/terms/measures>, <https://opendataproducts.org/odpv-v1.0/terms/BusinessObjective> .

<https://opendataproducts.org/odpv-v1.0/terms/measures> a skos:Concept ;
  skos:inScheme <https://opendataproducts.org/odpv-v1.0/> ;
  skos:prefLabel "measures"@en ;
  skos:definition "Indicates that one object measures another object, such as a KPI measuring a business objective or outcome."@en ;
  skos:notation "measures" ;
  dcterms:type "relationship" ;
  dcterms:isPartOf "relationships" ;
  skos:altLabel "tracks"@en, "monitors"@en, "evaluates"@en, "assesses"@en ;
